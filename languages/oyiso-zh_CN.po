msgid "不确定怎么配时，建议使用“按区间自动生成”；想精确控制每个奖项时，再使用“手动添加奖项”。"
msgstr "不确定怎么配时，建议使用“按区间自动生成”；想精确控制每个奖项时，再使用“手动添加奖项”。"

msgid "自动生成奖项"
msgstr "自动生成奖项"

msgid "系统会按照最小值到最大值自动生成所有奖项。你也可以单独提高或降低某些奖项的抽中概率。"
msgstr "系统会按照最小值到最大值自动生成所有奖项。你也可以单独提高或降低某些奖项的抽中概率。"

msgid "起始值"
msgstr "起始值"

msgid "结束值"
msgstr "结束值"

msgid "百分比填减免百分比，例如 10 表示减 10%；固定金额填优惠金额，例如 20。"
msgstr "百分比填减免百分比，例如 10 表示减 10%；固定金额填优惠金额，例如 20。"

msgid "百分比填减免百分比，例如 50 表示减 50%；固定金额填优惠金额，例如 50。"
msgstr "百分比填减免百分比，例如 50 表示减 50%；固定金额填优惠金额，例如 50。"

msgid "默认抽中权重"
msgstr "默认抽中权重"

msgid "数字越大越容易抽中。未单独设置的奖项都会使用这个值。"
msgstr "数字越大越容易抽中。未单独设置的奖项都会使用这个值。"

msgid "填写要单独调整的那个奖项值。"
msgstr "填写要单独调整的那个奖项值。"

msgid "抽中权重"
msgstr "抽中权重"

msgid "数字越大越容易抽中。"
msgstr "数字越大越容易抽中。"

msgid "单独调整部分奖项"
msgstr "单独调整部分奖项"

msgid "例如默认权重是 1，你可以把 50% 的权重改成 0.5，把 20% 的权重改成 3。"
msgstr "例如默认权重是 1，你可以把 50% 的权重改成 0.5，把 20% 的权重改成 3。"

msgid "只有你手动添加的奖项才会参与抽奖。适合精确控制固定几个折扣，例如 10%、20%、50%。"
msgstr "只有你手动添加的奖项才会参与抽奖。适合精确控制固定几个折扣，例如 10%、20%、50%。"

msgid "百分比填减免百分比，例如 25；固定金额填优惠金额，例如 20。"
msgstr "百分比填减免百分比，例如 25；固定金额填优惠金额，例如 20。"

msgid "每一项都是一个可抽中的奖项。没有添加的值不会参与抽奖。"
msgstr "每一项都是一个可抽中的奖项。没有添加的值不会参与抽奖。"

msgid "未中奖设置"
msgstr "未中奖设置"

msgid "加入未中奖结果"
msgstr "加入未中奖结果"

msgid "关闭后，用户每次都会抽中某个奖项。"
msgstr "关闭后，用户每次都会抽中某个奖项。"

msgid "未中奖提示"
msgstr "未中奖提示"

msgid "数字越大，越容易抽到未中奖。"
msgstr "数字越大，越容易抽到未中奖。"

msgid "每条规则填写一个概率。开启参与奖时，剩余概率会自动归入参与奖；关闭时，系统会把所有中奖规则按比例补足到 100%。"
msgstr "每条规则填写一个概率。开启参与奖时，剩余概率会自动归入参与奖；关闭时，系统会把所有中奖规则按比例补足到 100%。"

